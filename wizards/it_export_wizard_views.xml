<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_export_wizard_form" model="ir.ui.view">
        <field name="name">it.export.wizard.form</field>
        <field name="model">it.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Excel">
                <sheet>
                    <group string="Type d'export">
                        <field name="export_type" widget="radio"/>
                    </group>
                    <group string="Filtres optionnels">
                        <field name="department_id"
                               invisible="export_type not in ('inventory',)"/>
                        <field name="category_id"
                               invisible="export_type not in ('inventory',)"/>
                        <field name="date_from"
                               invisible="export_type not in ('maintenance_costs',)"/>
                        <field name="date_to"
                               invisible="export_type not in ('maintenance_costs',)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_export" string="Télécharger l'export Excel"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Excel</field>
        <field name="res_model">it.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('it_parc.group_it_manager'))]"/>
    </record>
</odoo>
