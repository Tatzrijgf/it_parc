<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_contract_renew_wizard_form" model="ir.ui.view">
        <field name="name">it.contract.renew.wizard.form</field>
        <field name="model">it.contract.renew.wizard</field>
        <field name="arch" type="xml">
            <form string="Renouveler le contrat">
                <sheet>
                    <group string="Contrat à renouveler">
                        <field name="contract_id" readonly="1"/>
                        <field name="current_end_date" readonly="1"/>
                    </group>
                    <group string="Nouveau contrat">
                        <field name="new_start_date"/>
                        <field name="duration_months"/>
                        <field name="new_end_date" readonly="1"/>
                        <field name="new_amount"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Notes relatives au renouvellement..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirmer le renouvellement"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
