<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Vue Liste ─────────────────────────────────────────────────────── -->
    <record id="view_it_intervention_list" model="ir.ui.view">
        <field name="name">it.intervention.list</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <list string="Interventions"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'in_progress'"
                  decoration-info="state == 'planned'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="intervention_type" widget="badge"/>
                <field name="technician_id"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="duration" optional="show"/>
                <field name="cost"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'planned'"
                    decoration-warning="state == 'in_progress'"
                    decoration-success="state == 'done'"
                    decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ── Vue Formulaire ────────────────────────────────────────────────── -->
    <record id="view_it_intervention_form" model="ir.ui.view">
        <field name="name">it.intervention.form</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <form string="Intervention">
                <header>
                    <button name="action_start" string="Démarrer"
                            type="object" class="btn-primary"
                            invisible="state != 'planned'"/>
                    <button name="action_done" string="Terminer"
                            type="object" class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Annuler"
                            type="object" class="btn-danger"
                            invisible="state in ('done','cancelled')"
                            confirm="Confirmer l'annulation de cette intervention ?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Informations générales">
                            <field name="equipment_id"/>
                            <field name="intervention_type"/>
                            <field name="technician_id"/>
                            <field name="cost"/>
                        </group>
                        <group string="Planification">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Décrire le problème constaté..."/>
                        </page>
                        <page string="Rapport d'intervention" name="report">
                            <field name="report" placeholder="Rapport détaillé de l'intervention..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Vue Calendrier ────────────────────────────────────────────────── -->
    <record id="view_it_intervention_calendar" model="ir.ui.view">
        <field name="name">it.intervention.calendar</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <calendar string="Planning des interventions"
                      date_start="date_start"
                      date_stop="date_end"
                      color="intervention_type"
                      mode="month">
                <field name="equipment_id"/>
                <field name="technician_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- ── Vue Recherche ─────────────────────────────────────────────────── -->
    <record id="view_it_intervention_search" model="ir.ui.view">
        <field name="name">it.intervention.search</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <search string="Rechercher une intervention">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="technician_id"/>
                <separator/>
                <filter name="filter_planned" string="Planifiées"
                        domain="[('state','=','planned')]"/>
                <filter name="filter_in_progress" string="En cours"
                        domain="[('state','=','in_progress')]"/>
                <filter name="filter_done" string="Terminées"
                        domain="[('state','=','done')]"/>
                <separator/>
                <filter name="filter_corrective" string="Correctives"
                        domain="[('intervention_type','=','corrective')]"/>
                <filter name="filter_preventive" string="Préventives"
                        domain="[('intervention_type','=','preventive')]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_equipment" string="Équipement"
                            context="{'group_by': 'equipment_id'}"/>
                    <filter name="group_technician" string="Technicien"
                            context="{'group_by': 'technician_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'intervention_type'}"/>
                    <filter name="group_month" string="Mois"
                            context="{'group_by': 'date_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ───────────────────────────────────────────────────────── -->
    <record id="action_it_intervention" model="ir.actions.act_window">
        <field name="name">Interventions</field>
        <field name="res_model">it.intervention</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_it_intervention_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune intervention enregistrée
            </p>
            <p>Créez votre première intervention de maintenance.</p>
        </field>
    </record>

    <!-- Action serveur : Export Excel coûts maintenance (depuis liste interventions) -->
    <record id="action_server_export_maintenance" model="ir.actions.server">
        <field name="name">Exporter coûts en Excel</field>
        <field name="model_id" ref="model_it_intervention"/>
        <field name="binding_model_id" ref="model_it_intervention"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Export Excel Maintenance',
    'res_model': 'it.export.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'default_export_type': 'maintenance_costs'},
}
        </field>
        <field name="groups_id" eval="[(4, ref('it_parc.group_it_manager'))]"/>
    </record>
</odoo>
