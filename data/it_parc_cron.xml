<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Tâche planifiée : Génération automatique des alertes (quotidienne) -->
        <record id="cron_it_generate_alerts" model="ir.cron">
            <field name="name">IT Parc : Génération automatique des alertes</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_alerts(); self.env['it.contract']._compute_state_cron()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="priority">10</field>
        </record>

        <!-- Paramètre système : seuil d'alerte par défaut (30 jours) -->
        <record id="param_it_alert_threshold" model="ir.config_parameter">
            <field name="key">it_parc.alert_threshold_days</field>
            <field name="value">30</field>
        </record>
    </data>
</odoo>
